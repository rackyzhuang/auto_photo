    "build": "tsc && vite build",
    "check:core": "node scripts/check-core.mjs",
    "check:ai-config": "node scripts/check-ai-config.mjs",
    "check:ai-safety": "node scripts/check-ai-safety.mjs",
    "check:ai-settings-ux": "node scripts/check-ai-settings-ux.mjs",
    "check:ai-tuning": "node scripts/check-ai-tuning.mjs",
    "check:compare-layout-ux": "node scripts/check-compare-layout-ux.mjs",
    "check:desktop-import-payload": "node scripts/check-desktop-import-payload.mjs",
    "check:desktop-import-paths": "node scripts/check-desktop-import-paths.mjs",
    "check:export-target-ux": "node scripts/check-export-target-ux.mjs",
    "check:export-conflicts": "node scripts/check-export-conflicts.mjs",
    "check:import-drop-ux": "node scripts/check-import-drop-ux.mjs",
    "check:export-queue": "node scripts/check-export-queue.mjs",
    "check:export-exif-fixtures": "node scripts/check-export-exif-fixtures.mjs",
    "check:jpg-fixtures": "node scripts/check-jpg-fixtures.mjs",
    "check:manual-acceptance": "node scripts/check-manual-acceptance-results.mjs",
    "check:parameter-inputs": "node scripts/check-parameter-inputs.mjs",
    "check:performance-diagnostics": "node scripts/check-performance-diagnostics.mjs",
    "check:preset-contact-sheets": "node scripts/check-preset-contact-sheets.mjs",
    "check:presets": "node scripts/check-presets.mjs",
    "check:preset-render": "node scripts/check-preset-render.mjs",
    "check:privacy": "node scripts/check-privacy.mjs",
    "check:raw-preview": "node scripts/check-raw-embedded-preview.mjs",
    "generate:preset-contact-sheets": "node scripts/generate-preset-contact-sheets.mjs",
    "generate:release-evidence": "node scripts/generate-release-evidence.mjs",
    "generate:release-readiness": "node scripts/generate-release-readiness.mjs",
    "prepare:jpg-fixtures": "node scripts/extract-raw-jpg-fixtures.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "tauri": "tauri",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "desktop:build:no-bundle": "tauri build --no-bundle",
