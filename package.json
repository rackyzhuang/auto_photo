{
  "name": "autophoto-client",
  "version": "0.1.9",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "tauri": "tauri",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "desktop:build:no-bundle": "tauri build --no-bundle",
    "desktop:build:windows": "tauri build --bundles msi,nsis",
    "desktop:build:mac": "tauri build --bundles app,dmg",
    "mobile:android:init": "tauri android init",
    "mobile:android:init:ci": "tauri android init --ci --skip-targets-install",
    "mobile:android:dev": "tauri android dev",
    "mobile:android:build:apk": "tauri android build --apk",
    "mobile:android:build:release": "tauri android build --apk --ci",
    "mobile:ios:init:ci": "tauri ios init --ci --skip-targets-install",
    "mobile:ios:dev": "tauri ios dev",
    "mobile:ios:build": "tauri ios build",
    "mobile:ios:build:simulator": "tauri ios build --target aarch64-sim --no-sign --ci",
    "mobile:ios:build:release": "tauri ios build --ci"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@vitejs/plugin-react": "^4.3.4",
    "exifr": "^7.1.3",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "typescript": "^5.7.2"
  }
}
